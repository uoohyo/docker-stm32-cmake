{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Docker: Build Image",
            "type": "shell",
            "command": "docker build -t uoohyo/stm32-cmake:latest .",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": []
        }
    ]
}
